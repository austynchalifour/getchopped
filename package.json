{
  "name": "getchopped",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run server:dev\" \"npm run client:dev\"",
    "server:dev": "nodemon server/index.js",
    "client:dev": "npm --prefix client run dev",
    "build": "npm --prefix client install && npm --prefix client run build",
    "start": "node server/index.js",
    "check": "node --check server/index.js && node --check server/jobStore.js && node --check server/pipeline.js && node --check server/services.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.57.0",
    "axios": "^1.7.9",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-session": "^1.18.1",
    "fluent-ffmpeg": "^2.1.3",
    "googleapis": "^144.0.0",
    "multer": "^1.4.5-lts.1",
    "nanoid": "^5.0.9"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "nodemon": "^3.1.9"
  }
}
